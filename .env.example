# Neon PostgreSQL connection string
# 1. Go to https://neon.tech and create a free account
# 2. Create a new project
# 3. Copy the connection string from the dashboard and replace below
DATABASE_URI=postgresql://REPLACE_WITH_YOUR_NEON_CONNECTION_STRING

# Payload CMS secret key (generate a random 32+ character string)
# You can generate one with: openssl rand -hex 32
PAYLOAD_SECRET=REPLACE_WITH_RANDOM_32_CHAR_STRING

# The public URL of your server (keep as localhost for local development)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
